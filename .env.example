# Analytics (paste your IDs, leave empty to disable)
# GOOGLE_ANALYTICS=G-XXXXXXXXXX
# CLARITY=your-clarity-id
# HOTJAR=your-hotjar-id
# TAG_MANAGER=GTM-XXXXXXX
# PLAUSIBLE=your-domain.com

# Cloudflare (for scripts: upload, cache, deploy)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# KV_NAMESPACE_ID=
# R2_BUCKET=inkwell-media

# Publishing API (set on Worker via wrangler secret)
# PUBLISH_TOKEN=sk-inkwell-publish-...
