---
import { config } from '../../lib/config'

const currentYear = new Date().getFullYear()

const sections = {
  discover: [
    { href: '/topics', label: 'Topics' },
    { href: '/blog', label: 'Blog' },
    { href: '/explore', label: 'Explore' },
    { href: '/search', label: 'Search' },
  ],
  build: [
    { href: '/labs', label: 'Labs' },
    { href: '/tools', label: 'Tools' },
    { href: '/products', label: 'Products' },
  ],
  ecosystem: [
    { href: '/team', label: 'Team' },
    { href: '/vision', label: 'Vision' },
    { href: '/about', label: 'About' },
    { href: 'https://github.com/Mumega-com', label: 'GitHub', external: true },
    { href: 'https://discord.gg/mumega', label: 'Discord', external: true },
  ],
  legal: [
    { href: '/privacy', label: 'Privacy' },
    { href: '/terms', label: 'Terms' },
    { href: `https://${config.domain}/rss.xml`, label: 'RSS', external: true },
  ],
}
---

<footer class="ink-footer">
  <div class="ink-footer-inner">
    <div class="ink-footer-grid">
      <div class="ink-footer-brand">
        <a href="/" class="ink-footer-name">{config.name}</a>
        <p class="ink-footer-tagline">{config.tagline}</p>
      </div>

      <nav class="ink-footer-col" aria-label="Discover">
        <span class="ink-footer-heading">Discover</span>
        {sections.discover.map((link) => (
          <a href={link.href} class="ink-footer-link">{link.label}</a>
        ))}
      </nav>

      <nav class="ink-footer-col" aria-label="Build">
        <span class="ink-footer-heading">Build</span>
        {sections.build.map((link) => (
          <a href={link.href} class="ink-footer-link">{link.label}</a>
        ))}
      </nav>

      <nav class="ink-footer-col" aria-label="Ecosystem">
        <span class="ink-footer-heading">Ecosystem</span>
        {sections.ecosystem.map((link) => (
          <a href={link.href} class="ink-footer-link" {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="ink-footer-bottom">
      <div class="ink-footer-bottom-left">
        <span>&copy; {currentYear} Mumega Inc.</span>
      </div>
      <div class="ink-footer-bottom-right">
        {sections.legal.map((link) => (
          <a href={link.href} class="ink-footer-legal" {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .ink-footer {
    border-top: 1px solid var(--ink-border);
    background: var(--ink-surface);
    margin-top: 4rem;
  }

  .ink-footer-inner {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 1.5rem;
  }

  .ink-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
  }

  .ink-footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ink-footer-name {
    font-family: var(--ink-font-display);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--ink-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .ink-footer-name:hover {
    color: var(--ink-primary);
  }

  .ink-footer-tagline {
    color: var(--ink-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
    max-width: 280px;
  }

  .ink-footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .ink-footer-heading {
    display: block;
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    margin-bottom: 0.5rem;
  }

  .ink-footer-link {
    font-size: 0.875rem;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .ink-footer-link:hover {
    color: var(--ink-primary);
  }

  .ink-footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--ink-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ink-footer-bottom-left span {
    font-size: 0.75rem;
    color: var(--ink-dim);
  }

  .ink-footer-bottom-right {
    display: flex;
    gap: 1.5rem;
  }

  .ink-footer-legal {
    font-size: 0.75rem;
    color: var(--ink-dim);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .ink-footer-legal:hover {
    color: var(--ink-muted);
  }

  @media (max-width: 768px) {
    .ink-footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .ink-footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .ink-footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .ink-footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
