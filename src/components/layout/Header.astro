---
import { config } from '../../lib/config'

interface Props {
  currentPath?: string
}

const { currentPath = Astro.url.pathname } = Astro.props

const navLinks = [
  { href: '/topics', label: 'Topics' },
  { href: '/labs', label: 'Labs' },
  { href: '/tools', label: 'Tools' },
  { href: '/blog', label: 'Blog' },
  { href: '/team', label: 'Team' },
  { href: '/explore', label: 'Explore' },
]

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/'
  return current.startsWith(href)
}
---

<header class="ink-header">
  <div class="ink-header-inner">
    <a href="/" class="ink-header-brand">
      {config.name}
    </a>

    <nav class="ink-header-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['ink-header-link', { active: isActive(link.href, currentPath) }]}
          aria-current={isActive(link.href, currentPath) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="ink-header-actions">
      <div class="ink-theme-toggle" role="radiogroup" aria-label="Theme">
        <button type="button" data-theme="light" aria-label="Light theme" class="ink-theme-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
        <button type="button" data-theme="dark" aria-label="Dark theme" class="ink-theme-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button type="button" data-theme="system" aria-label="System theme" class="ink-theme-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </button>
      </div>

      <button type="button" class="ink-search-trigger" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      <a href="https://app.mumega.com/login" class="ink-login-btn">Login</a>
    </div>
  </div>
</header>

<script is:inline>
;(function () {
  const STORAGE_KEY = 'inkwell-theme'

  function getStoredTheme() {
    if (typeof localStorage === 'undefined') return null
    return localStorage.getItem(STORAGE_KEY)
  }

  function setTheme(theme) {
    const root = document.documentElement

    if (theme === 'system') {
      localStorage.removeItem(STORAGE_KEY)
      document.cookie = STORAGE_KEY + '=; path=/; max-age=0'
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      root.classList.toggle('dark', prefersDark)
      root.classList.toggle('light', !prefersDark)
    } else {
      localStorage.setItem(STORAGE_KEY, theme)
      document.cookie = STORAGE_KEY + '=' + theme + '; path=/; max-age=31536000; SameSite=Lax'
      root.classList.toggle('dark', theme === 'dark')
      root.classList.toggle('light', theme === 'light')
    }

    updateButtons(theme)
  }

  function updateButtons(active) {
    document.querySelectorAll('.ink-theme-btn').forEach(function (btn) {
      var isActive = btn.dataset.theme === active
      btn.classList.toggle('active', isActive)
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false')
    })
  }

  // Init on load
  var stored = getStoredTheme()
  updateButtons(stored || 'system')

  // Bind click handlers
  document.querySelectorAll('.ink-theme-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      setTheme(btn.dataset.theme)
    })
  })

  // Search trigger opens command palette (Cmd+K)
  var searchBtn = document.querySelector('.ink-search-trigger')
  if (searchBtn) {
    searchBtn.addEventListener('click', function () {
      window.dispatchEvent(
        new KeyboardEvent('keydown', { key: 'k', metaKey: true, bubbles: true })
      )
    })
  }

  // Listen for system changes when in system mode
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
    if (!getStoredTheme()) {
      document.documentElement.classList.toggle('dark', e.matches)
      document.documentElement.classList.toggle('light', !e.matches)
    }
  })
})()
</script>

<style>
  .ink-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--ink-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ink-border);
  }

  .ink-header-inner {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ink-header-brand {
    font-family: var(--ink-font-display);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--ink-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .ink-header-nav {
    display: flex;
    gap: 0.25rem;
  }

  .ink-header-link {
    font-family: var(--ink-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: var(--ink-radius);
    transition: color 0.15s ease, background 0.15s ease;
  }

  .ink-header-link:hover {
    color: var(--ink-text);
    background: var(--ink-surface);
  }

  .ink-header-link.active {
    color: var(--ink-primary);
    font-weight: 600;
  }

  .ink-header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ink-theme-toggle {
    display: flex;
    align-items: center;
    background: var(--ink-surface);
    border-radius: var(--ink-radius);
    padding: 2px;
    gap: 2px;
  }

  .ink-theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    border-radius: calc(var(--ink-radius) - 2px);
    background: transparent;
    color: var(--ink-dim);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .ink-theme-btn:hover {
    color: var(--ink-text);
  }

  .ink-theme-btn.active {
    background: var(--ink-bg);
    color: var(--ink-primary);
  }

  .ink-search-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    background: transparent;
    color: var(--ink-muted);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .ink-search-trigger:hover {
    color: var(--ink-text);
    border-color: var(--ink-muted);
  }

  .ink-login-btn {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    background: var(--ink-primary);
    color: var(--ink-bg);
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .ink-login-btn:hover {
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .ink-header-nav {
      display: none;
    }
  }
</style>
