---
interface Props {
  type: 'info' | 'warning' | 'tip' | 'danger'
}

const { type } = Astro.props

const colorMap: Record<string, string> = {
  info: 'var(--ink-secondary)',
  warning: '#F59E0B',
  tip: 'var(--ink-accent)',
  danger: 'var(--ink-danger)',
}

const iconMap: Record<string, string> = {
  info: 'i',
  warning: 'triangle',
  tip: 'lightbulb',
  danger: 'x',
}

const labelMap: Record<string, string> = {
  info: 'Info',
  warning: 'Warning',
  tip: 'Tip',
  danger: 'Danger',
}

const borderColor = colorMap[type]
const icon = iconMap[type]
const label = labelMap[type]
---

<aside class="ink-callout" style={`--callout-color: ${borderColor}`} role="note" aria-label={label}>
  <div class="ink-callout-icon">
    {icon === 'i' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
    )}
    {icon === 'triangle' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    )}
    {icon === 'lightbulb' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18h6"/>
        <path d="M10 22h4"/>
        <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>
      </svg>
    )}
    {icon === 'x' && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
    )}
  </div>
  <div class="ink-callout-content">
    <span class="ink-callout-label">{label}</span>
    <slot />
  </div>
</aside>

<style>
  .ink-callout {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--callout-color);
    background: color-mix(in srgb, var(--callout-color) 6%, var(--ink-surface));
    border-radius: 0 var(--ink-radius) var(--ink-radius) 0;
    margin: 1.5rem 0;
  }

  .ink-callout-icon {
    flex-shrink: 0;
    color: var(--callout-color);
    margin-top: 0.125rem;
  }

  .ink-callout-content {
    flex: 1;
    min-width: 0;
  }

  .ink-callout-label {
    display: block;
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--callout-color);
    margin-bottom: 0.375rem;
  }

  .ink-callout-content :global(p) {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-text);
  }

  .ink-callout-content :global(p + p) {
    margin-top: 0.5rem;
  }
</style>
