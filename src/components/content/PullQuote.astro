---

<figure class="ink-pullquote">
  <div class="ink-pullquote-line" aria-hidden="true"></div>
  <blockquote class="ink-pullquote-text">
    <slot />
  </blockquote>
  <div class="ink-pullquote-line" aria-hidden="true"></div>
</figure>

<style>
  .ink-pullquote {
    margin: 2.5rem auto;
    padding: 0 1rem;
    max-width: var(--ink-content-width);
    text-align: center;
  }

  .ink-pullquote-line {
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--ink-primary),
      transparent
    );
    margin: 0 auto;
    max-width: 12rem;
  }

  .ink-pullquote-text {
    font-family: var(--ink-font-body);
    font-size: 1.375rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ink-text);
    padding: 1.5rem 0;
    margin: 0;
  }

  .ink-pullquote-text :global(p) {
    margin: 0;
  }
</style>
