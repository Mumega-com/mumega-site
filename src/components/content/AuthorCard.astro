---
interface Props {
  name: string
  bio?: string
  avatarUrl?: string
}

const { name, bio, avatarUrl } = Astro.props

const initials = name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .toUpperCase()
  .slice(0, 2)
---

<div class="ink-author">
  <div class="ink-author-avatar">
    {avatarUrl ? (
      <img src={avatarUrl} alt={name} class="ink-author-img" loading="lazy" decoding="async" />
    ) : (
      <span class="ink-author-initials">{initials}</span>
    )}
  </div>
  <div class="ink-author-info">
    <span class="ink-author-name">{name}</span>
    <span class="ink-author-subtitle">Published with Mumega</span>
    {bio && <p class="ink-author-bio">{bio}</p>}
  </div>
</div>

<style>
  .ink-author {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    margin: 2rem 0;
  }

  .ink-author-avatar {
    flex-shrink: 0;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    border: 2px solid var(--ink-primary);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--ink-primary) 12%, var(--ink-bg));
  }

  .ink-author-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ink-author-initials {
    font-family: var(--ink-font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-primary);
    user-select: none;
  }

  .ink-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .ink-author-name {
    font-family: var(--ink-font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-text);
    line-height: 1.3;
  }

  .ink-author-subtitle {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--ink-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ink-author-bio {
    margin: 0.375rem 0 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-muted);
  }
</style>
