---
import Base from './Base.astro'

interface Props {
  nodeCount?: number
  edgeCount?: number
  items?: Array<{
    title: string
    slug: string
    collection: string
    description?: string
    date?: string
    tags?: string[]
  }>
}

const {
  nodeCount = 0,
  edgeCount = 0,
  items = [],
} = Astro.props
---

<Base title="Explore" description="Explore the knowledge network">
  <div class="explore-layout">
    {/* Header */}
    <header class="explore-header">
      <h1 class="explore-title">Explore the network</h1>
      <div class="explore-stats">
        <span class="explore-stat">
          <strong>{nodeCount}</strong> nodes
        </span>
        <span class="explore-stat-sep">&middot;</span>
        <span class="explore-stat">
          <strong>{edgeCount}</strong> edges
        </span>
      </div>
    </header>

    {/* Knowledge graph mount point */}
    <div class="explore-graph">
      <slot />
    </div>

    {/* Content grid */}
    {items.length > 0 && (
      <section class="explore-grid-section">
        <h2 class="explore-grid-title">All content</h2>
        <div class="explore-grid">
          {items.map((item) => (
            <a href={`/${item.collection}/${item.slug}`} class="explore-card">
              <span class="explore-card-collection">{item.collection}</span>
              <h3 class="explore-card-title">{item.title}</h3>
              {item.description && (
                <p class="explore-card-desc">{item.description}</p>
              )}
              <div class="explore-card-footer">
                {item.date && (
                  <time datetime={item.date}>
                    {new Date(item.date).toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                  </time>
                )}
                {item.tags && item.tags.length > 0 && (
                  <div class="explore-card-tags">
                    {item.tags.slice(0, 3).map((tag) => (
                      <span class="explore-card-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .explore-layout {
    min-height: 100vh;
    width: 100%;
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Header */
  .explore-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .explore-title {
    font-family: var(--ink-font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink-text);
    margin-bottom: 0.5rem;
  }

  .explore-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink-muted);
    font-family: var(--ink-font-mono);
    font-size: 0.875rem;
  }

  .explore-stat strong {
    color: var(--ink-primary);
    font-weight: 600;
  }

  .explore-stat-sep {
    opacity: 0.4;
  }

  /* Graph container */
  .explore-graph {
    width: 100%;
    min-height: 60vh;
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    overflow: hidden;
    margin-bottom: 3rem;
  }

  /* Content grid */
  .explore-grid-section {
    margin-top: 2rem;
  }

  .explore-grid-title {
    font-family: var(--ink-font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink-text);
    margin-bottom: 1.25rem;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* Cards */
  .explore-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: border-color 150ms ease, transform 150ms ease;
  }

  .explore-card:hover {
    border-color: var(--ink-primary);
    transform: translateY(-2px);
  }

  .explore-card-collection {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-secondary);
    margin-bottom: 0.5rem;
  }

  .explore-card-title {
    font-family: var(--ink-font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink-text);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .explore-card-desc {
    font-size: 0.825rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .explore-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .explore-card-footer time {
    font-size: 0.75rem;
    color: var(--ink-dim);
  }

  .explore-card-tags {
    display: flex;
    gap: 0.375rem;
  }

  .explore-card-tag {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    color: var(--ink-dim);
    background: var(--ink-border);
    padding: 0.1em 0.5em;
    border-radius: 9999px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .explore-layout {
      padding: 1rem;
    }

    .explore-graph {
      min-height: 50vh;
    }

    .explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
