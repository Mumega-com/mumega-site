---
import Base from '../layouts/Base.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import JsonLd from '../components/seo/JsonLd.astro'
import { KnowledgeGraph } from '../components/visualization/KnowledgeGraph'
import { contentCollectionLabels, loadContentDirectory, routeFor, sortDirectoryEntries } from '../lib/content-directory'

const directory = await loadContentDirectory()
const entries = sortDirectoryEntries(directory.entries)

const nodes = entries.map((entry) => ({
  slug: `${entry.collection}:${entry.id}`,
  title: entry.title,
  tags: entry.tags.filter((tag) => tag.toLowerCase() !== 'beta'),
  url: routeFor(entry.collection, entry.id),
}))

interface GraphEdge {
  source: string
  target: string
  type: string
}

const edges: GraphEdge[] = []
const seen = new Set<string>()

for (const item of entries) {
  const itemTags = item.tags.filter((tag) => tag.toLowerCase() !== 'beta')
  if (itemTags.length === 0) continue

  for (const other of entries) {
    if (item.collection === other.collection && item.id === other.id) continue

    const otherTags = other.tags.filter((tag) => tag.toLowerCase() !== 'beta')
    const sharedTags = itemTags.filter((tag) => otherTags.includes(tag))
    if (sharedTags.length === 0) continue

    const source = `${item.collection}:${item.id}`
    const target = `${other.collection}:${other.id}`
    const key = [source, target].sort().join('::')
    if (seen.has(key)) continue
    seen.add(key)
    edges.push({ source, target, type: 'tag' })
  }
}

function formatDate(entry: { date?: Date; updated?: Date }): string {
  const date = entry.updated ?? entry.date
  if (!date) return ''
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
}
---

<Base title="Explore" description="Explore the knowledge graph — see how ideas connect across the network.">
  <JsonLd siteOnly />
  <Header />

  <main class="explore-page">
    <div class="explore-header">
      <h1 class="explore-title">Explore the network</h1>
      <p class="explore-stats">
        <span class="explore-stat">{nodes.length} nodes</span>
        <span class="explore-dot">&middot;</span>
        <span class="explore-stat">{edges.length} connections</span>
      </p>
    </div>

    <div class="graph-container">
      <KnowledgeGraph nodes={nodes} edges={edges} client:visible />
    </div>

    <section class="explore-content">
      <h2 class="explore-section-title">All content</h2>
      <div class="content-grid">
        {entries.map((entry) => (
          <a href={routeFor(entry.collection, entry.id)} class="content-card">
            <span class="content-kind">{contentCollectionLabels[entry.collection]}</span>
            <span class="content-date">{formatDate(entry)}</span>
            <h3 class="content-title">{entry.title}</h3>
            {entry.description && <p class="content-desc">{entry.description}</p>}
            <div class="content-tags">
              {entry.tags.filter((tag) => tag.toLowerCase() !== 'beta').map((tag) => (
                <span class="content-tag">#{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  main {
    padding-top: 3.5rem;
  }

  .explore-page {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .explore-header {
    margin-bottom: 2rem;
  }

  .explore-title {
    font-family: var(--ink-font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink-text);
    margin-bottom: 0.5rem;
  }

  .explore-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
  }

  .explore-stat {
    color: var(--ink-primary);
    font-weight: 600;
  }

  .explore-dot {
    color: var(--ink-dim);
  }

  .graph-container {
    margin-bottom: 4rem;
  }

  .explore-content {
    border-top: 1px solid var(--ink-border);
    padding-top: 2rem;
  }

  .explore-section-title {
    font-family: var(--ink-font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .content-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem;
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .content-card:hover {
    border-color: var(--ink-primary);
    transform: translateY(-1px);
  }

  .content-kind {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-primary);
    font-weight: 600;
  }

  .content-date {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-dim);
  }

  .content-title {
    font-family: var(--ink-font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-text);
    line-height: 1.3;
    margin: 0;
  }

  .content-desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-muted);
    margin: 0;
  }

  .content-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .content-tag {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    color: var(--ink-muted);
    background: var(--ink-bg);
    padding: 0.0625rem 0.375rem;
    border-radius: 9999px;
    border: 1px solid var(--ink-border);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
