---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Base title="Dashboard — Mumega">
  <Header />
  <main class="dashboard">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <nav class="dash-nav">
        <a href="/dashboard" class="active">Overview</a>
        <a href="/dashboard/billing">Billing</a>
        <a href="/dashboard/seats">Team</a>
        <a href="/dashboard/usage">Usage</a>
        <a href="/dashboard/connect">Connect</a>
      </nav>
    </div>

    <div id="loading" class="state-msg">Loading...</div>
    <div id="not-auth" class="state-msg" style="display:none">
      <h2>Not logged in</h2>
      <p>Please <a href="/connect">sign up</a> or check your email for a login link.</p>
    </div>
    <div id="content" style="display:none">
      <div class="cards">
        <div class="card">
          <div class="card-label">Plan</div>
          <div class="card-value" id="plan">—</div>
        </div>
        <div class="card">
          <div class="card-label">Status</div>
          <div class="card-value" id="status">—</div>
        </div>
        <div class="card">
          <div class="card-label">Site</div>
          <div class="card-value" id="site-url">—</div>
        </div>
        <div class="card">
          <div class="card-label">MCP Connected</div>
          <div class="card-value" id="mcp-status">—</div>
        </div>
      </div>

      <section class="section">
        <h2>Quick Actions</h2>
        <div class="actions">
          <a href="/dashboard/connect" class="action-btn">View MCP Config</a>
          <a href="/dashboard/seats" class="action-btn">Manage Team</a>
          <a href="/dashboard/billing" class="action-btn">Billing</a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .dashboard { max-width: 960px; margin: 0 auto; padding: 5rem 2rem 4rem; }
  .dash-header { margin-bottom: 2rem; }
  .dash-header h1 {
    font-family: var(--ink-font-display);
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .dash-nav {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--ink-border);
    padding-bottom: 0;
    flex-wrap: wrap;
  }
  .dash-nav a {
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: var(--ink-font-mono);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
  }
  .dash-nav a:hover { color: var(--ink-text); }
  .dash-nav a.active { color: var(--ink-primary); border-bottom-color: var(--ink-primary); }

  .state-msg { color: var(--ink-muted); font-size: 0.9375rem; padding: 2rem 0; }
  .state-msg h2 { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0 0 0.5rem; }
  .state-msg a { color: var(--ink-primary); }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 1.5rem;
  }
  .card-label {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    font-weight: 600;
  }
  .card-value {
    font-family: var(--ink-font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--ink-text);
    margin-top: 0.5rem;
  }

  .section { margin-top: 2rem; }
  .section h2 {
    font-family: var(--ink-font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 1rem;
  }
  .actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .action-btn {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 0.75rem 1.5rem;
    color: var(--ink-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-family: var(--ink-font-mono);
    transition: border-color 0.15s;
  }
  .action-btn:hover { border-color: var(--ink-primary); color: var(--ink-primary); }
</style>

<script>
  const API = 'https://api.mumega.com'

  async function loadDashboard() {
    try {
      const resp = await fetch(`${API}/auth/me`, { credentials: 'include' })
      if (!resp.ok) throw new Error('not auth')
      const data = await resp.json()

      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('content')!.style.display = 'block'

      const t = data.tenant
      if (t) {
        document.getElementById('plan')!.textContent = t.plan?.toUpperCase() || '—'
        const statusEl = document.getElementById('status')!
        statusEl.textContent = t.status || '—'
        statusEl.style.color = t.status === 'active' ? 'var(--ink-accent)' : 'var(--ink-muted)'
        document.getElementById('site-url')!.textContent = t.subdomain ? `${t.subdomain}.mumega.com` : '—'
        document.getElementById('mcp-status')!.textContent = t.mcp_connected ? 'Active' : 'Not connected'
        if (t.mcp_connected) {
          document.getElementById('mcp-status')!.style.color = 'var(--ink-accent)'
        }
      }
    } catch {
      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('not-auth')!.style.display = 'block'
    }
  }

  loadDashboard()
</script>
