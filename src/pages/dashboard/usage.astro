---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Base title="Usage — Mumega">
  <Header />
  <main class="dashboard">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <nav class="dash-nav">
        <a href="/dashboard">Overview</a>
        <a href="/dashboard/billing">Billing</a>
        <a href="/dashboard/seats">Team</a>
        <a href="/dashboard/usage" class="active">Usage</a>
        <a href="/dashboard/connect">Connect</a>
      </nav>
    </div>

    <div id="loading" class="state-msg">Loading...</div>
    <div id="not-auth" class="state-msg" style="display:none">
      <h2>Not logged in</h2>
      <p>Please <a href="/connect">sign up</a> or check your email for a login link.</p>
    </div>
    <div id="content" style="display:none">

      <section class="section">
        <div class="section-row">
          <h2>Usage Overview</h2>
          <span class="period-label" id="period-label">This billing period</span>
        </div>
        <div class="cards">
          <div class="card">
            <div class="card-label">API Calls</div>
            <div class="card-value" id="stat-api">—</div>
            <div class="card-sub" id="stat-api-pct"></div>
          </div>
          <div class="card">
            <div class="card-label">Agent Minutes</div>
            <div class="card-value" id="stat-agent">—</div>
            <div class="card-sub" id="stat-agent-pct"></div>
          </div>
          <div class="card">
            <div class="card-label">Memory Entries</div>
            <div class="card-value" id="stat-memory">—</div>
            <div class="card-sub" id="stat-memory-pct"></div>
          </div>
          <div class="card">
            <div class="card-label">Storage</div>
            <div class="card-value" id="stat-storage">—</div>
            <div class="card-sub" id="stat-storage-pct"></div>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>API Calls — Last 30 Days</h2>
        <div class="chart-wrap">
          <canvas id="chart-api" height="120"></canvas>
        </div>
      </section>

      <section class="section">
        <h2>Top Tools Used</h2>
        <div id="tools-list" class="tools-list">
          <p class="state-msg">No tool usage data yet.</p>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Base>

<style>
  .dashboard { max-width: 960px; margin: 0 auto; padding: 5rem 2rem 4rem; }
  .dash-header { margin-bottom: 2rem; }
  .dash-header h1 {
    font-family: var(--ink-font-display);
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .dash-nav {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--ink-border);
    flex-wrap: wrap;
  }
  .dash-nav a {
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: var(--ink-font-mono);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
  }
  .dash-nav a:hover { color: var(--ink-text); }
  .dash-nav a.active { color: var(--ink-primary); border-bottom-color: var(--ink-primary); }

  .state-msg { color: var(--ink-muted); font-size: 0.9375rem; padding: 1rem 0; }
  .state-msg h2 { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0 0 0.5rem; }
  .state-msg a { color: var(--ink-primary); }

  .section { margin-bottom: 2.5rem; }
  .section-row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .section h2 {
    font-family: var(--ink-font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0;
  }
  .period-label {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
  }

  /* Stat cards */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
  .card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 1.25rem 1.5rem;
  }
  .card-label {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    font-weight: 600;
  }
  .card-value {
    font-family: var(--ink-font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin-top: 0.375rem;
  }
  .card-sub { font-size: 0.75rem; color: var(--ink-dim); margin-top: 0.25rem; }

  /* Bar chart */
  .chart-wrap {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 1.5rem;
    overflow: hidden;
  }
  canvas { width: 100%; display: block; }

  /* Tools list */
  .tools-list { display: flex; flex-direction: column; gap: 0; }
  .tool-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--ink-border);
    gap: 1rem;
  }
  .tool-row:last-child { border-bottom: none; }
  .tool-row-name {
    font-size: 0.9375rem;
    color: var(--ink-text);
    font-family: var(--ink-font-mono);
    flex: 1;
  }
  .tool-row-bar-wrap {
    flex: 2;
    height: 4px;
    background: var(--ink-border);
    border-radius: 99px;
    overflow: hidden;
  }
  .tool-row-bar {
    height: 100%;
    background: var(--ink-secondary);
    border-radius: 99px;
  }
  .tool-row-count {
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    width: 60px;
    text-align: right;
    flex-shrink: 0;
  }
</style>

<script>
  const API = 'https://api.mumega.com'

  function fmtNum(n: number): string {
    if (n >= 1000000) return `${(n / 1000000).toFixed(1)}M`
    if (n >= 1000) return `${(n / 1000).toFixed(1)}K`
    return n.toString()
  }

  function fmtBytes(bytes: number): string {
    if (bytes >= 1073741824) return `${(bytes / 1073741824).toFixed(1)} GB`
    if (bytes >= 1048576) return `${(bytes / 1048576).toFixed(1)} MB`
    if (bytes >= 1024) return `${(bytes / 1024).toFixed(1)} KB`
    return `${bytes} B`
  }

  function drawBarChart(canvas: HTMLCanvasElement, labels: string[], values: number[]) {
    const dpr = window.devicePixelRatio || 1
    const w = canvas.offsetWidth || canvas.parentElement!.clientWidth
    const h = 120
    canvas.width = w * dpr
    canvas.height = h * dpr
    canvas.style.width = w + 'px'
    canvas.style.height = h + 'px'

    const ctx = canvas.getContext('2d')!
    ctx.scale(dpr, dpr)

    const max = Math.max(...values, 1)
    const count = labels.length
    const barW = Math.floor((w - 40) / count) - 4
    const chartH = h - 24

    // Get CSS var colors from the document
    const rootStyle = getComputedStyle(document.documentElement)
    const primaryColor = rootStyle.getPropertyValue('--ink-primary').trim() || '#D4A017'
    const mutedColor = rootStyle.getPropertyValue('--ink-dim').trim() || '#666'

    ctx.clearRect(0, 0, w, h)

    for (let i = 0; i < count; i++) {
      const barH = Math.round((values[i] / max) * chartH)
      const x = 20 + i * (barW + 4)
      const y = chartH - barH

      ctx.fillStyle = primaryColor
      ctx.globalAlpha = values[i] === 0 ? 0.15 : 0.85
      ctx.beginPath()
      ctx.roundRect(x, y, barW, barH, [2, 2, 0, 0])
      ctx.fill()
      ctx.globalAlpha = 1

      // Label every 5th or first/last
      if (i === 0 || i === count - 1 || i % 5 === 0) {
        ctx.fillStyle = mutedColor
        ctx.font = `9px monospace`
        ctx.textAlign = 'center'
        ctx.fillText(labels[i], x + barW / 2, h - 4)
      }
    }
  }

  async function loadUsage() {
    try {
      const resp = await fetch(`${API}/auth/me`, { credentials: 'include' })
      if (!resp.ok) throw new Error('not auth')

      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('content')!.style.display = 'block'

      const usageResp = await fetch(`${API}/dashboard/overview`, { credentials: 'include' })
      if (!usageResp.ok) return

      const data = await usageResp.json()
      const u = data.usage ?? {}

      // Stat cards
      document.getElementById('stat-api')!.textContent = fmtNum(u.api_calls ?? 0)
      if (u.api_calls_limit) {
        const pct = Math.round((u.api_calls / u.api_calls_limit) * 100)
        document.getElementById('stat-api-pct')!.textContent = `${pct}% of ${fmtNum(u.api_calls_limit)} limit`
      }

      document.getElementById('stat-agent')!.textContent = fmtNum(u.agent_minutes ?? 0)
      if (u.agent_minutes_limit) {
        const pct = Math.round((u.agent_minutes / u.agent_minutes_limit) * 100)
        document.getElementById('stat-agent-pct')!.textContent = `${pct}% of ${fmtNum(u.agent_minutes_limit)} min limit`
      }

      document.getElementById('stat-memory')!.textContent = fmtNum(u.memory_entries ?? 0)
      document.getElementById('stat-storage')!.textContent = fmtBytes(u.storage_bytes ?? 0)

      // Daily chart
      if (data.daily?.length > 0) {
        const canvas = document.getElementById('chart-api') as HTMLCanvasElement
        const labels: string[] = data.daily.map((d: { date: string }) => {
          const dt = new Date(d.date)
          return `${dt.getMonth() + 1}/${dt.getDate()}`
        })
        const values: number[] = data.daily.map((d: { api_calls: number }) => d.api_calls ?? 0)
        // Defer so canvas has layout
        requestAnimationFrame(() => drawBarChart(canvas, labels, values))
      }

      // Top tools
      if (data.top_tools?.length > 0) {
        const container = document.getElementById('tools-list')!
        container.innerHTML = ''
        const maxCalls = data.top_tools[0].calls
        for (const tool of data.top_tools) {
          const pct = Math.round((tool.calls / maxCalls) * 100)
          const row = document.createElement('div')
          row.className = 'tool-row'
          row.innerHTML = `
            <span class="tool-row-name">${tool.name}</span>
            <div class="tool-row-bar-wrap"><div class="tool-row-bar" style="width:${pct}%"></div></div>
            <span class="tool-row-count">${fmtNum(tool.calls)}</span>
          `
          container.appendChild(row)
        }
      }
    } catch {
      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('not-auth')!.style.display = 'block'
    }
  }

  loadUsage()
</script>
