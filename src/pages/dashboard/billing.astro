---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Base title="Billing — Mumega">
  <Header />
  <main class="dashboard">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <nav class="dash-nav">
        <a href="/dashboard">Overview</a>
        <a href="/dashboard/billing" class="active">Billing</a>
        <a href="/dashboard/seats">Team</a>
        <a href="/dashboard/usage">Usage</a>
        <a href="/dashboard/connect">Connect</a>
      </nav>
    </div>

    <div id="loading" class="state-msg">Loading...</div>
    <div id="not-auth" class="state-msg" style="display:none">
      <h2>Not logged in</h2>
      <p>Please <a href="/connect">sign up</a> or check your email for a login link.</p>
    </div>
    <div id="content" style="display:none">

      <section class="section">
        <h2>Current Plan</h2>
        <div class="plan-card">
          <div class="plan-meta">
            <div class="plan-name-row">
              <span class="plan-name" id="plan-name">—</span>
              <span class="plan-badge" id="plan-status">—</span>
            </div>
            <div class="plan-price" id="plan-price">—</div>
            <div class="plan-renew" id="plan-renew"></div>
          </div>
          <div class="plan-actions">
            <button class="btn-outline" id="btn-upgrade">Upgrade Plan</button>
            <button class="btn-ghost" id="btn-cancel">Cancel Subscription</button>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>Usage This Period</h2>
        <div class="usage-rows" id="usage-rows">
          <div class="usage-row">
            <span class="usage-label">API Calls</span>
            <div class="usage-bar-wrap">
              <div class="usage-bar" id="bar-api"></div>
            </div>
            <span class="usage-num" id="num-api">—</span>
          </div>
          <div class="usage-row">
            <span class="usage-label">Seats</span>
            <div class="usage-bar-wrap">
              <div class="usage-bar" id="bar-seats"></div>
            </div>
            <span class="usage-num" id="num-seats">—</span>
          </div>
          <div class="usage-row">
            <span class="usage-label">Squads</span>
            <div class="usage-bar-wrap">
              <div class="usage-bar" id="bar-squads"></div>
            </div>
            <span class="usage-num" id="num-squads">—</span>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>Invoices</h2>
        <div class="invoices" id="invoices">
          <p class="state-msg">No invoices yet.</p>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Base>

<style>
  .dashboard { max-width: 960px; margin: 0 auto; padding: 5rem 2rem 4rem; }
  .dash-header { margin-bottom: 2rem; }
  .dash-header h1 {
    font-family: var(--ink-font-display);
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .dash-nav {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--ink-border);
    flex-wrap: wrap;
  }
  .dash-nav a {
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: var(--ink-font-mono);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
  }
  .dash-nav a:hover { color: var(--ink-text); }
  .dash-nav a.active { color: var(--ink-primary); border-bottom-color: var(--ink-primary); }

  .state-msg { color: var(--ink-muted); font-size: 0.9375rem; padding: 1rem 0; }
  .state-msg h2 { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0 0 0.5rem; }
  .state-msg a { color: var(--ink-primary); }

  .section { margin-bottom: 2.5rem; }
  .section h2 {
    font-family: var(--ink-font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 1rem;
  }

  /* Plan card */
  .plan-card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .plan-meta { display: flex; flex-direction: column; gap: 0.375rem; }
  .plan-name-row { display: flex; align-items: center; gap: 0.75rem; }
  .plan-name {
    font-family: var(--ink-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink-text);
  }
  .plan-badge {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    padding: 0.125rem 0.625rem;
    border-radius: 99px;
    background: var(--ink-accent);
    color: #fff;
  }
  .plan-price {
    font-family: var(--ink-font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
  }
  .plan-renew { font-size: 0.8125rem; color: var(--ink-dim); }
  .plan-actions { display: flex; flex-direction: column; gap: 0.75rem; min-width: 160px; }
  .btn-outline {
    padding: 0.625rem 1.25rem;
    background: var(--ink-primary);
    color: var(--ink-bg);
    border: none;
    border-radius: var(--ink-radius);
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-outline:hover { opacity: 0.85; }
  .btn-ghost {
    padding: 0.625rem 1.25rem;
    background: transparent;
    color: var(--ink-muted);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--ink-muted); color: var(--ink-text); }

  /* Usage bars */
  .usage-rows { display: flex; flex-direction: column; gap: 1rem; }
  .usage-row { display: flex; align-items: center; gap: 1rem; }
  .usage-label {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    color: var(--ink-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    width: 80px;
    flex-shrink: 0;
  }
  .usage-bar-wrap {
    flex: 1;
    height: 6px;
    background: var(--ink-border);
    border-radius: 99px;
    overflow: hidden;
  }
  .usage-bar {
    height: 100%;
    background: var(--ink-primary);
    border-radius: 99px;
    width: 0%;
    transition: width 0.6s ease;
  }
  .usage-num {
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    width: 100px;
    text-align: right;
    flex-shrink: 0;
  }

  /* Invoices */
  .invoices { display: flex; flex-direction: column; gap: 0; }
  .invoice-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--ink-border);
    gap: 1rem;
  }
  .invoice-row:last-child { border-bottom: none; }
  .invoice-date { font-size: 0.875rem; color: var(--ink-muted); }
  .invoice-amount {
    font-family: var(--ink-font-mono);
    font-size: 0.9375rem;
    color: var(--ink-text);
    font-weight: 600;
  }
  .invoice-status {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.125rem 0.5rem;
    border-radius: 99px;
  }
  .invoice-status.paid { background: color-mix(in srgb, var(--ink-accent) 15%, transparent); color: var(--ink-accent); }
  .invoice-pdf {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    color: var(--ink-primary);
    text-decoration: none;
  }
  .invoice-pdf:hover { text-decoration: underline; }
</style>

<script>
  const API = 'https://api.mumega.com'

  const PLAN_PRICES: Record<string, string> = {
    starter: '$29/mo',
    growth: '$79/mo',
    scale: '$199/mo',
  }

  function setBar(id: string, numId: string, used: number, total: number) {
    const pct = total > 0 ? Math.min(100, Math.round((used / total) * 100)) : 0
    const bar = document.getElementById(id) as HTMLElement
    if (bar) bar.style.width = `${pct}%`
    const num = document.getElementById(numId) as HTMLElement
    if (num) num.textContent = total > 0 ? `${used.toLocaleString()} / ${total.toLocaleString()}` : `${used}`
  }

  async function loadBilling() {
    try {
      const [meResp, billingResp] = await Promise.all([
        fetch(`${API}/auth/me`, { credentials: 'include' }),
        fetch(`${API}/dashboard/billing`, { credentials: 'include' }),
      ])
      if (!meResp.ok) throw new Error('not auth')

      const me = await meResp.json()
      const t = me.tenant

      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('content')!.style.display = 'block'

      if (t) {
        document.getElementById('plan-name')!.textContent = t.plan ? t.plan.charAt(0).toUpperCase() + t.plan.slice(1) : '—'
        document.getElementById('plan-price')!.textContent = PLAN_PRICES[t.plan] || '—'
        const badge = document.getElementById('plan-status')!
        badge.textContent = t.status || '—'
        if (t.status !== 'active') badge.style.background = 'var(--ink-border)'
      }

      if (billingResp.ok) {
        const billing = await billingResp.json()

        if (billing.renews_at) {
          document.getElementById('plan-renew')!.textContent = `Renews ${new Date(billing.renews_at).toLocaleDateString()}`
        }

        if (billing.usage) {
          const u = billing.usage
          setBar('bar-api', 'num-api', u.api_calls ?? 0, u.api_calls_limit ?? 0)
          setBar('bar-seats', 'num-seats', u.seats ?? 0, u.seats_limit ?? 0)
          setBar('bar-squads', 'num-squads', u.squads ?? 0, u.squads_limit ?? 0)
        }

        if (billing.invoices?.length > 0) {
          const container = document.getElementById('invoices')!
          container.innerHTML = ''
          for (const inv of billing.invoices) {
            const row = document.createElement('div')
            row.className = 'invoice-row'
            row.innerHTML = `
              <span class="invoice-date">${new Date(inv.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="invoice-amount">$${(inv.amount_cents / 100).toFixed(2)}</span>
              <span class="invoice-status ${inv.status}">${inv.status}</span>
              ${inv.pdf_url ? `<a class="invoice-pdf" href="${inv.pdf_url}" target="_blank">PDF</a>` : ''}
            `
            container.appendChild(row)
          }
        }
      }

      document.getElementById('btn-upgrade')?.addEventListener('click', () => {
        window.location.href = '/connect#signup'
      })
      document.getElementById('btn-cancel')?.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to cancel your subscription?')) return
        const r = await fetch(`${API}/dashboard/billing/cancel`, { method: 'POST', credentials: 'include' })
        if (r.ok) alert('Subscription cancelled. Access continues until end of billing period.')
        else alert('Could not cancel. Please email support@mumega.com.')
      })
    } catch {
      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('not-auth')!.style.display = 'block'
    }
  }

  loadBilling()
</script>
