---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
---

<Base title="Team — Mumega">
  <Header />
  <main class="dashboard">
    <div class="dash-header">
      <h1>Dashboard</h1>
      <nav class="dash-nav">
        <a href="/dashboard">Overview</a>
        <a href="/dashboard/billing">Billing</a>
        <a href="/dashboard/seats" class="active">Team</a>
        <a href="/dashboard/usage">Usage</a>
        <a href="/dashboard/connect">Connect</a>
      </nav>
    </div>

    <div id="loading" class="state-msg">Loading...</div>
    <div id="not-auth" class="state-msg" style="display:none">
      <h2>Not logged in</h2>
      <p>Please <a href="/connect">sign up</a> or check your email for a login link.</p>
    </div>
    <div id="content" style="display:none">

      <section class="section section-row">
        <div>
          <h2>Team Seats</h2>
          <p class="section-desc" id="seat-count">0 seats used</p>
        </div>
        <button class="btn-primary" id="btn-add">+ Add Seat</button>
      </section>

      <div id="seats-list" class="seats-list">
        <p class="state-msg">No seats yet.</p>
      </div>

      <div id="add-form" class="add-form" style="display:none">
        <h3>Add New Seat</h3>
        <div class="field">
          <label for="seat-email">Email address</label>
          <input type="email" id="seat-email" placeholder="teammate@example.com" />
        </div>
        <div class="field">
          <label for="seat-label">Label (optional)</label>
          <input type="text" id="seat-label" placeholder="e.g. Marketing Claude" />
        </div>
        <div class="form-actions">
          <button class="btn-primary" id="btn-confirm-add">Create Seat</button>
          <button class="btn-ghost" id="btn-cancel-add">Cancel</button>
        </div>
        <div id="add-result" class="add-result" style="display:none">
          <div class="result-label">Seat token (share via email — shown once)</div>
          <pre id="seat-token" class="token-box"></pre>
          <button class="copy-btn" data-target="seat-token">Copy token</button>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</Base>

<style>
  .dashboard { max-width: 960px; margin: 0 auto; padding: 5rem 2rem 4rem; }
  .dash-header { margin-bottom: 2rem; }
  .dash-header h1 {
    font-family: var(--ink-font-display);
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }
  .dash-nav {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--ink-border);
    flex-wrap: wrap;
  }
  .dash-nav a {
    color: var(--ink-muted);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: var(--ink-font-mono);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
  }
  .dash-nav a:hover { color: var(--ink-text); }
  .dash-nav a.active { color: var(--ink-primary); border-bottom-color: var(--ink-primary); }

  .state-msg { color: var(--ink-muted); font-size: 0.9375rem; padding: 1rem 0; }
  .state-msg h2 { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0 0 0.5rem; }
  .state-msg a { color: var(--ink-primary); }

  .section { margin-bottom: 1.5rem; }
  .section-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; flex-wrap: wrap; }
  .section h2 {
    font-family: var(--ink-font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 0.25rem;
  }
  .section-desc { font-size: 0.875rem; color: var(--ink-muted); margin: 0; }

  .btn-primary {
    padding: 0.625rem 1.25rem;
    background: var(--ink-primary);
    color: var(--ink-bg);
    border: none;
    border-radius: var(--ink-radius);
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    padding: 0.625rem 1.25rem;
    background: transparent;
    color: var(--ink-muted);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--ink-muted); color: var(--ink-text); }

  /* Seats list */
  .seats-list { display: flex; flex-direction: column; gap: 0; }
  .seat-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid var(--ink-border);
    gap: 1rem;
    flex-wrap: wrap;
  }
  .seat-row:last-child { border-bottom: none; }
  .seat-info { display: flex; flex-direction: column; gap: 0.125rem; }
  .seat-email { font-size: 0.9375rem; color: var(--ink-text); }
  .seat-meta {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .seat-actions { display: flex; gap: 0.5rem; align-items: center; }
  .seat-badge {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.125rem 0.5rem;
    border-radius: 99px;
    background: color-mix(in srgb, var(--ink-accent) 15%, transparent);
    color: var(--ink-accent);
  }
  .seat-badge.inactive { background: var(--ink-border); color: var(--ink-dim); }
  .btn-revoke {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-muted);
    background: none;
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 0.25rem 0.625rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-revoke:hover { border-color: #e55353; color: #e55353; }

  /* Add form */
  .add-form {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 1.5rem;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .add-form h3 {
    font-family: var(--ink-font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0;
  }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-dim);
    font-weight: 600;
  }
  .field input {
    width: 100%;
    max-width: 400px;
    padding: 0.625rem 0.875rem;
    background: var(--ink-bg);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    color: var(--ink-text);
    font-size: 0.9375rem;
    font-family: var(--ink-font-body);
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .field input:focus { outline: none; border-color: var(--ink-primary); }
  .form-actions { display: flex; gap: 0.75rem; }

  /* Result */
  .add-result { display: flex; flex-direction: column; gap: 0.5rem; }
  .result-label {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-dim);
    font-weight: 600;
  }
  .token-box {
    background: var(--ink-bg);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    padding: 0.875rem 1rem;
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    word-break: break-all;
    white-space: pre-wrap;
    margin: 0;
  }
  .copy-btn {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-primary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    align-self: flex-start;
  }
  .copy-btn:hover { text-decoration: underline; }
</style>

<script>
  const API = 'https://api.mumega.com'

  async function loadSeats() {
    try {
      const resp = await fetch(`${API}/auth/me`, { credentials: 'include' })
      if (!resp.ok) throw new Error('not auth')

      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('content')!.style.display = 'block'

      await refreshSeats()
    } catch {
      document.getElementById('loading')!.style.display = 'none'
      document.getElementById('not-auth')!.style.display = 'block'
    }
  }

  async function refreshSeats() {
    const resp = await fetch(`${API}/dashboard/seats`, { credentials: 'include' })
    if (!resp.ok) return
    const data = await resp.json()
    const seats: Array<{ id: string; email: string; label?: string; status: string; created_at: string }> = data.seats ?? []

    document.getElementById('seat-count')!.textContent = `${seats.length} seat${seats.length !== 1 ? 's' : ''} used`

    const container = document.getElementById('seats-list')!
    if (seats.length === 0) {
      container.innerHTML = '<p class="state-msg">No seats yet. Add a seat to give a teammate or AI tool access.</p>'
      return
    }

    container.innerHTML = ''
    for (const seat of seats) {
      const row = document.createElement('div')
      row.className = 'seat-row'
      row.dataset.id = seat.id
      const created = new Date(seat.created_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })
      row.innerHTML = `
        <div class="seat-info">
          <span class="seat-email">${seat.email || seat.label || 'Unnamed seat'}</span>
          <span class="seat-meta">${seat.label ? seat.label + ' · ' : ''}Added ${created}</span>
        </div>
        <div class="seat-actions">
          <span class="seat-badge ${seat.status !== 'active' ? 'inactive' : ''}">${seat.status}</span>
          <button class="btn-revoke" data-id="${seat.id}">Revoke</button>
        </div>
      `
      container.appendChild(row)
    }

    container.querySelectorAll('.btn-revoke').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id
        if (!confirm('Revoke this seat? The token will stop working immediately.')) return
        const r = await fetch(`${API}/dashboard/seats/${id}/revoke`, { method: 'POST', credentials: 'include' })
        if (r.ok) await refreshSeats()
        else alert('Could not revoke seat. Please try again.')
      })
    })
  }

  // Show/hide add form
  document.getElementById('btn-add')?.addEventListener('click', () => {
    const form = document.getElementById('add-form')!
    form.style.display = form.style.display === 'none' ? 'flex' : 'none'
    if (form.style.display === 'flex') {
      document.getElementById('add-result')!.style.display = 'none'
      ;(document.getElementById('seat-email') as HTMLInputElement).value = ''
      ;(document.getElementById('seat-label') as HTMLInputElement).value = ''
    }
  })

  document.getElementById('btn-cancel-add')?.addEventListener('click', () => {
    document.getElementById('add-form')!.style.display = 'none'
  })

  document.getElementById('btn-confirm-add')?.addEventListener('click', async () => {
    const email = (document.getElementById('seat-email') as HTMLInputElement).value.trim()
    const label = (document.getElementById('seat-label') as HTMLInputElement).value.trim()
    if (!email) { alert('Please enter an email address.'); return }

    const btn = document.getElementById('btn-confirm-add') as HTMLButtonElement
    btn.textContent = 'Creating...'
    btn.disabled = true

    try {
      const resp = await fetch(`${API}/dashboard/seats`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, label }),
      })
      const data = await resp.json()
      if (!resp.ok) { alert(data.detail || 'Could not create seat.'); return }

      document.getElementById('seat-token')!.textContent = data.token
      document.getElementById('add-result')!.style.display = 'flex'
      await refreshSeats()
    } finally {
      btn.textContent = 'Create Seat'
      btn.disabled = false
    }
  })

  // Copy button
  document.querySelectorAll<HTMLElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target
      const el = document.getElementById(target ?? '')
      if (!el) return
      navigator.clipboard.writeText(el.textContent ?? '')
      const orig = btn.textContent
      btn.textContent = 'Copied!'
      setTimeout(() => { btn.textContent = orig }, 2000)
    })
  })

  loadSeats()
</script>
