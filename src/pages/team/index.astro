---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { getCollection } from 'astro:content'

const allMembers = await getCollection('team')
const dormant = allMembers.filter((m) => m.data.status === 'dormant')
const active = allMembers.filter((m) => m.data.status !== 'dormant').sort((a, b) => {
  const typeOrder = { human: 0, agent: 1 } as Record<string, number>
  const typeDiff = (typeOrder[a.data.type] ?? 1) - (typeOrder[b.data.type] ?? 1)
  if (typeDiff !== 0) return typeDiff
  return b.data.tasks_completed - a.data.tasks_completed
})

const statusColors: Record<string, string> = { active: 'var(--ink-accent)', idle: 'var(--ink-primary)', dormant: 'var(--ink-dim)' }
---

<Base title="Team — Mumega" description="The agents and humans who build the Mumega ecosystem.">
  <JsonLd siteOnly />
  <Header />

  <main class="page">
    <div class="page-inner">
      <h1 class="page-title">Team</h1>
      <p class="page-subtitle">Humans and AI agents working side by side. Same tasks, same standards.</p>

      <div class="team-grid">
        {active.map((member) => (
          <a href={`/team/${member.id}`} class="member-card">
            <div class="member-header">
              <span class="member-status" style={`background: ${statusColors[member.data.status] || 'var(--ink-dim)'}`}></span>
              <span class="member-type">{member.data.type}</span>
              {member.data.squad && <span class="member-squad">{member.data.squad}</span>}
            </div>
            <h2 class="member-name">{member.data.title}</h2>
            <p class="member-role">{member.data.role}</p>
            {member.data.origin && <p class="member-origin">{member.data.origin}</p>}
            {member.data.model && <span class="member-model">{member.data.model}</span>}
          </a>
        ))}
      </div>

      {/* Dormant */}
      {dormant.length > 0 && (
        <div class="dormant-section">
          <h2 class="dormant-title">Dormant</h2>
          {dormant.map((member) => (
            <a href={`/team/${member.id}`} class="dormant-card">
              <span class="dormant-dot"></span>
              <span class="dormant-name">{member.data.title}</span>
              <span class="dormant-role">{member.data.role}</span>
              {member.data.origin && <span class="dormant-origin">{member.data.origin}</span>}
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<style>
  main { padding-top: 3.5rem; }
  .page { max-width: var(--ink-page-width); margin: 0 auto; padding: 4rem 1.5rem; }
  .page-title { font-family: var(--ink-font-display); font-size: 2.5rem; font-weight: 700; color: var(--ink-text); letter-spacing: -0.03em; margin-bottom: 0.5rem; }
  .page-subtitle { color: var(--ink-muted); font-size: 1.125rem; margin-bottom: 3rem; }
  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }
  .member-card { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; background: var(--ink-surface); border: 1px solid var(--ink-border); border-radius: var(--ink-radius); text-decoration: none; transition: border-color 0.15s ease; }
  .member-card:hover { border-color: var(--ink-primary); }
  .member-header { display: flex; align-items: center; gap: 0.5rem; }
  .member-squad { font-family: var(--ink-font-mono); font-size: 0.625rem; color: var(--ink-secondary); }
  .member-origin { font-size: 0.8125rem; color: var(--ink-muted); line-height: 1.4; margin: 0; font-style: italic; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .dormant-section { margin-top: 3rem; }
  .dormant-title { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-dim); margin-bottom: 1rem; }
  .dormant-card { display: flex; align-items: baseline; gap: 0.75rem; padding: 1rem 1.25rem; border-bottom: 1px solid var(--ink-border); text-decoration: none; transition: opacity 0.15s; flex-wrap: wrap; }
  .dormant-card:first-of-type { border-top: 1px solid var(--ink-border); }
  .dormant-card:hover { opacity: 0.7; }
  .dormant-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-dim); flex-shrink: 0; margin-top: 0.3rem; }
  .dormant-name { font-weight: 600; color: var(--ink-dim); font-size: 0.9375rem; }
  .dormant-role { font-size: 0.8125rem; color: var(--ink-dim); }
  .dormant-origin { font-size: 0.75rem; color: var(--ink-dim); font-style: italic; width: 100%; padding-left: 1.25rem; }
  .member-status { width: 8px; height: 8px; border-radius: 50%; }
  .member-type { font-family: var(--ink-font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-dim); }
  .member-name { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0; }
  .member-role { font-size: 0.875rem; color: var(--ink-muted); margin: 0; }
  .member-model { font-family: var(--ink-font-mono); font-size: 0.6875rem; color: var(--ink-dim); }
  .member-skills { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.25rem; }
  .member-skill { font-family: var(--ink-font-mono); font-size: 0.625rem; padding: 0.125rem 0.375rem; background: var(--ink-bg); border: 1px solid var(--ink-border); border-radius: calc(var(--ink-radius) - 2px); color: var(--ink-dim); }
</style>
