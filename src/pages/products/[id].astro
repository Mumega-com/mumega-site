---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const products = await getCollection('products')
  return products.map((product) => ({ params: { id: product.id }, props: { product } }))
}

const { product } = Astro.props
const { Content } = await render(product)
---

<Base title={`${product.data.title} — Inkwell`} description={product.data.description}>
  <JsonLd siteOnly />
  <Header />

  <main class="page">
    <div class="page-inner">
      <div class="product-header">
        {product.data.marketplace && <span class="product-marketplace">{product.data.marketplace}</span>}
        <h1>{product.data.title}</h1>
        <p class="product-desc">{product.data.description}</p>
        {product.data.tags.length > 0 && (
          <div class="product-tags">
            {product.data.tags.map((tag) => (
              <a href={`/tag/${tag}`} class="product-tag">#{tag}</a>
            ))}
          </div>
        )}
        <div class="product-actions">
          {product.data.price && <span class="product-price">{product.data.price}</span>}
          {product.data.marketplace_url && <a href={product.data.marketplace_url} target="_blank" rel="noopener noreferrer" class="product-cta">Get it</a>}
        </div>
        {product.data.features.length > 0 && (
          <ul class="product-features">
            {product.data.features.map((f) => <li>{f}</li>)}
          </ul>
        )}
      </div>
      <div class="ink-prose">
        <Content />
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  main { padding-top: 3.5rem; }
  .page { max-width: var(--ink-page-width); margin: 0 auto; padding: 4rem 1.5rem; }
  .page-inner { max-width: var(--ink-content-width); margin: 0 auto; }
  .product-header { margin-bottom: 2rem; }
  .product-marketplace { font-family: var(--ink-font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-secondary); font-weight: 600; }
  h1 { font-family: var(--ink-font-display); font-size: 2.5rem; font-weight: 700; color: var(--ink-text); letter-spacing: -0.03em; margin: 0.5rem 0; }
  .product-desc { color: var(--ink-muted); font-size: 1.125rem; line-height: 1.6; margin: 0 0 1rem; }
  .product-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1rem; }
  .product-tag { font-family: var(--ink-font-mono); font-size: 0.6875rem; color: var(--ink-primary); padding: 0.125rem 0.5rem; border-radius: 9999px; border: 1px solid var(--ink-primary); text-decoration: none; }
  .product-tag:hover { background: color-mix(in srgb, var(--ink-primary) 8%, var(--ink-surface)); }
  .product-actions { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .product-price { font-family: var(--ink-font-display); font-size: 1.5rem; font-weight: 700; color: var(--ink-primary); }
  .product-cta { font-family: var(--ink-font-mono); font-size: 0.875rem; font-weight: 700; padding: 0.625rem 1.5rem; background: var(--ink-primary); color: var(--ink-bg); border-radius: var(--ink-radius); text-decoration: none; transition: opacity 0.15s ease; }
  .product-cta:hover { opacity: 0.9; }
  .product-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .product-features li { font-size: 0.9375rem; color: var(--ink-text); padding-left: 1.25rem; position: relative; }
  .product-features li::before { content: ''; position: absolute; left: 0; top: 0.5em; width: 6px; height: 6px; border-radius: 50%; background: var(--ink-accent); }
</style>
