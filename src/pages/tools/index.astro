---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { getCollection } from 'astro:content'

const allTools = await getCollection('tools')
const tools = allTools.sort((a, b) => b.data.weight - a.data.weight)

const typeLabels: Record<string, string> = { skill: 'Skill', plugin: 'Plugin', 'mcp-server': 'MCP Server', sdk: 'SDK', integration: 'Integration' }
---

<Base title="Tools — Inkwell" description="AI-first tools, skills, plugins, and MCP servers. Ready to use by agents and developers.">
  <JsonLd siteOnly />
  <Header />

  <main class="page">
    <div class="page-inner">
      <h1 class="page-title">Tools</h1>
      <p class="page-subtitle">Skills, plugins, MCP servers, and integrations. Built for agents, usable by anyone.</p>

      <div class="tools-grid">
        {tools.map((tool) => (
          <a href={`/tools/${tool.id}`} class="tool-card">
            <div class="tool-header">
              <span class="tool-type">{typeLabels[tool.data.type] || tool.data.type}</span>
              <span class="tool-status">{tool.data.status}</span>
            </div>
            <h2 class="tool-title">{tool.data.title}</h2>
            <p class="tool-desc">{tool.data.description}</p>
            {tool.data.install && <code class="tool-install">{tool.data.install}</code>}
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  main { padding-top: 3.5rem; }
  .page { max-width: var(--ink-page-width); margin: 0 auto; padding: 4rem 1.5rem; }
  .page-title { font-family: var(--ink-font-display); font-size: 2.5rem; font-weight: 700; color: var(--ink-text); letter-spacing: -0.03em; margin-bottom: 0.5rem; }
  .page-subtitle { color: var(--ink-muted); font-size: 1.125rem; margin-bottom: 3rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .tool-card { display: flex; flex-direction: column; gap: 0.75rem; padding: 1.5rem; background: var(--ink-surface); border: 1px solid var(--ink-border); border-radius: var(--ink-radius); text-decoration: none; transition: border-color 0.15s ease; }
  .tool-card:hover { border-color: var(--ink-primary); }
  .tool-header { display: flex; justify-content: space-between; align-items: center; }
  .tool-type { font-family: var(--ink-font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-secondary); font-weight: 600; }
  .tool-status { font-family: var(--ink-font-mono); font-size: 0.6875rem; color: var(--ink-dim); }
  .tool-title { font-family: var(--ink-font-display); font-size: 1.25rem; font-weight: 700; color: var(--ink-text); margin: 0; letter-spacing: -0.01em; }
  .tool-desc { font-size: 0.875rem; color: var(--ink-muted); line-height: 1.5; margin: 0; }
  .tool-install { font-family: var(--ink-font-mono); font-size: 0.75rem; padding: 0.375rem 0.75rem; background: var(--ink-bg); border: 1px solid var(--ink-border); border-radius: calc(var(--ink-radius) - 2px); color: var(--ink-dim); display: block; overflow-x: auto; }
</style>
