---
import Base from '../layouts/Base.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { getEntry, render } from 'astro:content'

const page = await getEntry('pages', 'terms')
if (!page) throw new Error('Terms page not found')
const { Content } = await render(page)
---

<Base title={page.data.title} description={page.data.description}>
  <Header />
  <main class="page"><article class="page-inner ink-prose"><Content /></article></main>
  <Footer />
</Base>

<style>
  main { padding-top: 3.5rem; }
  .page { max-width: var(--ink-page-width); margin: 0 auto; padding: 4rem 1.5rem; }
  .page-inner { max-width: var(--ink-content-width); margin: 0 auto; }
</style>
