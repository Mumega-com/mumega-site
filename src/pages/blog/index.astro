---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog', (entry) => entry.data.status === 'published')
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
}
---

<Base title="Blog" description="Dispatches, build journals, experiments, and release notes from the Mumega reference implementation.">
  <JsonLd siteOnly />
  <Header />

  <main class="blog-listing">
    <div class="blog-header">
      <h1 class="blog-page-title">From the reference implementation</h1>
      <p class="blog-page-desc">
        Dispatches on content, publishing, integrations, and the system around them.
      </p>
    </div>

    <div class="post-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <span class="post-date">{formatDate(new Date(post.data.date))}</span>
            <span class="post-author">{post.data.author}</span>
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          {post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
          <div class="post-footer">
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="post-tag" data-tag={tag}>{tag}</span>
              ))}
            </div>
            <span class="post-read">Read &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Base>

<style>
  main {
    padding-top: 3.5rem;
  }

  .blog-listing {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-page-title {
    font-family: var(--ink-font-display);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink-text);
    margin-bottom: 0.5rem;
  }

  .blog-page-desc {
    font-size: 1.125rem;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .post-card:hover {
    border-color: var(--ink-primary);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-date {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    color: var(--ink-dim);
  }

  .post-author {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
  }

  .post-title {
    font-family: var(--ink-font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--ink-text);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-tag {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-muted);
    background: var(--ink-bg);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    border: 1px solid var(--ink-border);
  }

  .post-read {
    font-family: var(--ink-font-mono);
    font-size: 0.75rem;
    color: var(--ink-primary);
    flex-shrink: 0;
  }
</style>
